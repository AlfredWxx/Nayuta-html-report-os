# Personal HTML Report OS - Environment Configuration
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# GitHub Configuration
# =============================================================================

# GitHub Personal Access Token with repo scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# GitHub repository owner (username or organization)
GITHUB_OWNER=yourusername

# GitHub repository name
GITHUB_REPO=report-os

# Target branch for file commits
GITHUB_BRANCH=main

# =============================================================================
# API Authentication
# =============================================================================

# API keys for external projects to publish reports
# Format: API_KEY_{PROJECT_NAME}={random_key}
# Projects will use the value as x-api-key header

API_KEY_PROJECT1=proj1_random_key_here
API_KEY_PROJECT2=proj2_random_key_here
API_KEY_DEMO=demo_key_for_testing

# =============================================================================
# Site Configuration
# =============================================================================

# Public URL of the deployed site (for generating report URLs)
SITE_URL=https://yourusername.github.io/report-os

# =============================================================================
# Rate Limiting
# =============================================================================

# Requests per minute per API key (default: 100)
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# Optional: Supabase (Future Use)
# =============================================================================

# Uncomment if/when Supabase integration is needed
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key